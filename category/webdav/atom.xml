ethods PROPFIND OPTIONS;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             create_full_put_path on;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             dav_access user:rw group:r all:r;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             auth_basic &amp;quot;Authorized Users Only&amp;quot;;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             auth_basic_user_file /etc/nginx/.htpasswd;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             client_max_body_size 5G;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;                &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;           error_page   500 502 503 504  /50x.html;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;           location = /50x.html &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;               root   /etc/nginx/html;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;             &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;server &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    listen 8080;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    error_log /etc/nginx/logs/jianguoyun.error.log error;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    access_log  /etc/nginx/logs/jianguoyun.access.log combined;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt; &lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    location / &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        root /home/yk/www/nginx/jianguoyun;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        autoindex on;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        dav_methods PUT DELETE MKCOL COPY MOVE;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        dav_ext_methods PROPFIND OPTIONS;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        create_full_put_path on;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        dav_access user:rw group:r all:r;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        auth_basic &amp;quot;Authorized Users Only&amp;quot;;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;        auth_basic_user_file /etc/nginx/.htpasswd;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    # HTTPS server&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #server &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    listen       443 ssl;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    server_name  localhost;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_certificate      cert.pem;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_certificate_key  cert.key;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_session_cache    shared:SSL:1m;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_session_timeout  5m;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_ciphers  HIGH:!aNULL:!MD5;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    ssl_prefer_server_ciphers  on;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    location / &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #        root   html;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #        index  index.html index.htm;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #    &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    #&amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&amp;#125;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;br&gt;（2）设置webdav帐号和密码：&lt;br&gt;&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;root@yk-pc:/etc/nginx# echo -n &amp;#x27;yk:&amp;#x27; | tee /etc/nginx/.htpasswd&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk:root@yk-pc:/etc/nginx# openssl passwd -apr1 | tee -a /etc/nginx/.htpasswd&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;Password: &lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;Verifying - Password: &lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;$apr1$6aLRK.3F$gg76W8E9vT65vn1cE/Mk41&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;br&gt;（3）挂载到坚果云方法&lt;br&gt;&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:~$ sudo apt-get install davfs2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:~$ mkdir -p /home/yk/www/nginx/jianguoyun&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:~$ sudo vim  /etc/davfs2/davfs2.conf&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;#ignore_dav_header 0&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;br&gt;  改为：&lt;br&gt;&lt;code&gt;ignore_dav_header 1&lt;/code&gt;&lt;br&gt;  挂载：&lt;br&gt;&lt;code&gt;yk@yk-pc:~$ sudo mount -t davfs https://dav.jianguoyun.com/dav/ /home/yk/www/nginx/jianguoyun&lt;/code&gt;&lt;br&gt;取消挂载：&lt;br&gt;&lt;code&gt;yk@yk-pc:~$ sudo fusermount -u /home/yk/www/nginx/jianguoyun&lt;/code&gt;&lt;/p&gt;
&lt;p&gt;（4）&lt;code&gt;nginx&lt;/code&gt;加入到&lt;code&gt;systemctl&lt;/code&gt;服务运行&lt;br&gt;  &lt;code&gt;yk@yk-pc:~$ sudo vim /usr/lib/systemd/system/nginx.service&lt;/code&gt;&lt;br&gt;输入以下内容并保存&lt;br&gt;&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;9&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;10&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;11&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;12&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;[Unit]&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;Description=nginx&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;After=network.target&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;[Service]&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;Type=forking&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;PIDFile=/etc/nginx/logs/nginx.pid&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;ExecStart=/etc/nginx/sbin/nginx&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;ExecReload=/etc/nginx/sbin/nginx -s reload&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;ExecStop=/etc/nginx/sbin/nginx -s stop&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;PrivateTmp=true&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;[Install]&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;WantedBy=multi-user.target&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;br&gt;（5）常用命令：&lt;br&gt;&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:~$ systemctl daemon-reload&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:~$ systemctl start/stop/reload nginx&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;p&gt;四、手机用的连接为webdav软件：&lt;br&gt;   &lt;strong&gt;苹果：FE文件管理器、ES文件浏览器&lt;/strong&gt;&lt;br&gt;   &lt;strong&gt;安卓：CX文件管理器、ES文件浏览器&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;五、一些问题及解决方法：&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;&lt;p&gt;查找进程：&lt;br&gt;查询端口：&lt;br&gt;&lt;code&gt;ps -ef |grep nginx&lt;/code&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;&lt;p&gt;开放端口：&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/logs$ sudo apt-get install iptables&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/logs$ sudo ln -s /usr/sbin/iptables /usr/bin/iptables  //建立软连接&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/logs$ sudo iptables -I INPUT -p tcp --dport 81 -j ACCEPT  //开放81端口&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;p&gt;持久化规则：这里我们需要在安装一下工具来帮我们实现，这里我们使用 &lt;code&gt;iptables-persistent&lt;/code&gt;&lt;br&gt;安装&lt;code&gt;iptables-persistent&lt;/code&gt;&lt;br&gt;&lt;code&gt;yk@yk-pc:/etc/nginx/logs$ sudo apt-get install iptables-persistent&lt;/code&gt;&lt;br&gt;持久化规则&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/logs$ sudo netfilter-persistent save&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/logs$ sudo netfilter-persistent reload&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;p&gt;完成上述操作就可以永久打开我们需要的端口了&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;&lt;p&gt;关于权限问题：&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt; yk@yk-pc:/etc/nginx/conf$ sudo vim nginx.conf&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt; [sudo] yk 的密码：&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;#user  nobody;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;p&gt;注释掉&lt;code&gt;user&lt;/code&gt;，改为&lt;br&gt;&lt;code&gt;user  nginx;&lt;/code&gt;&lt;br&gt;重新加载出现：错误提示如下：&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ sudo nginx -s reload&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;nginx: [emerg] getpwnam(&amp;quot;nginx&amp;quot;) failed in /etc/nginx/conf/nginx.conf:2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ sudo nginx -s closed&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;nginx: invalid option: &amp;quot;-s closed&amp;quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ sudo nginx -s stop&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;nginx: [emerg] getpwnam(&amp;quot;nginx&amp;quot;) failed in /etc/nginx/conf/nginx.conf:2&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;p&gt;&lt;strong&gt;解决办法：&lt;/strong&gt;&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ sudo useradd -s /sbin/nologin -M  nginx&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;useradd：用户“nginx”已存在&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ id nginx&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;uid=117(nginx) gid=125(nginx) 组=125(nginx)&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$ systemctl start nginx&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;yk@yk-pc:/etc/nginx/conf$  sudo nginx -s reload&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;/li&gt;
&lt;li&gt;&lt;p&gt;&lt;code&gt;make upgrade&lt;/code&gt; 平滑升级&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;/sbin/mount.davfs: mounting failed; the server does not support WebDAV&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;p&gt;原因是&lt;code&gt;mount.davfs&lt;/code&gt;命令在挂载时和 &lt;code&gt;WebDAV&lt;/code&gt; 服务器建立连接，并通过 &lt;code&gt;libneon&lt;/code&gt;库的 &lt;code&gt;ne_options&lt;/code&gt; 函数发送 &lt;code&gt;HTTP OPTIONS&lt;/code&gt; 请求获取 &lt;code&gt;WebDAV&lt;/code&gt; 服务器能力，虽然返回成功但判断坚果云 &lt;code&gt;WebDAV&lt;/code&gt; 服务器不支持 &lt;code&gt;Class 1 WebDAV&lt;/code&gt;，因此直接报错挂载失败。&lt;br&gt;看到这里解决办法也就简单了，&lt;code&gt;davfs2&lt;/code&gt; 提供了通过配置文件禁用 &lt;code&gt;WebDAV&lt;/code&gt;头检测的功能，&lt;/p&gt;
&lt;figure class=&#34;highlight plaintext&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;直接修改 /etc/davfs2/davfs2.conf 配置文件解注释并改为：ignore_dav_header 1&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;p&gt;参考：&lt;/p&gt;
